#!/usr/bin/env bash
# pngquant 有损压缩 PNG（仍为 .png）。默认：images_small → 复制为 images_pngquant 后量化。
# 用法：
#   chmod +x pngquant_images.sh
#   ./pngquant_images.sh
# 可选环境变量：
#   BASE=/home/ccxx/colmap_ws SRC_NAME=images_small DST_NAME=images_pngquant COLORS=256 ./pngquant_images.sh

set -euo pipefail

BASE="${BASE:-/home/ccxx/colmap_ws}"
SRC_NAME="${SRC_NAME:-images_small}"
DST_NAME="${DST_NAME:-images_pngquant}"
COLORS="${COLORS:-256}"

SRC="${BASE}/${SRC_NAME}"
DST="${BASE}/${DST_NAME}"

if [[ ! -d "$SRC" ]]; then
  echo "错误：源目录不存在: $SRC" >&2
  exit 1
fi

if ! command -v pngquant >/dev/null 2>&1; then
  echo "请先安装: sudo apt install -y pngquant" >&2
  exit 1
fi

echo "源: $SRC"
echo "目标: $DST（先复制再覆盖为量化 PNG，调色板颜色数=$COLORS）"

rm -rf "$DST"
cp -a "$SRC" "$DST"

cd "$DST"
shopt -s nullglob
files=( *.png )
total=${#files[@]}
if [[ "$total" -eq 0 ]]; then
  echo "错误：目录内没有 .png: $DST" >&2
  exit 1
fi

i=0
for f in "${files[@]}"; do
  i=$((i + 1))
  echo "[$i/$total] $f"
  pngquant --ext .png --force "$COLORS" "$f"
done

cd "$BASE"
echo "完成。体积对比:"
du -sh "$SRC" "$DST"
